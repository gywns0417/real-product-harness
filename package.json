{
  "name": "real-product-harness",
  "version": "0.1.0",
  "private": true,
  "description": "CLI harness for real-product AI agent workflows with approval gates.",
  "type": "commonjs",
  "bin": {
    "rph": "./dist/apps/cli/src/index.js",
    "real-product-harness": "./dist/apps/cli/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check:install": "node scripts/install-smoke.mjs",
    "dev": "tsx apps/cli/src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "rph": "node dist/apps/cli/src/index.js",
    "work-clock": "node scripts/work-clock.mjs",
    "smoke:productize": "node scripts/productize-smoke.mjs",
    "smoke:hermes-e2e": "node scripts/hermes-e2e-smoke.mjs",
    "smoke:setup-chat": "node scripts/setup-live-chat-smoke.mjs",
    "smoke:provider-onboarding": "node scripts/provider-onboarding-smoke.mjs",
    "smoke:provider-interactive-onboarding": "node scripts/provider-interactive-onboarding-smoke.mjs",
    "smoke:mcp-runtime": "node scripts/mcp-runtime-smoke.mjs",
    "smoke:mutable-mcp-sidecar": "node scripts/mutable-mcp-sidecar-smoke.mjs",
    "smoke:notion-readback": "node scripts/notion-readback-smoke.mjs",
    "smoke:github-readback": "node scripts/github-readback-smoke.mjs",
    "smoke:github-onboarding": "node scripts/github-onboarding-smoke.mjs",
    "smoke:mutable-action": "node scripts/mutable-action-smoke.mjs",
    "smoke:handoff-worker-race": "node scripts/handoff-worker-race-smoke.mjs",
    "smoke:top-level-golden-path": "node scripts/top-level-golden-path-smoke.mjs",
    "smoke:install-e2e": "node scripts/install-e2e-smoke.mjs",
    "live:matrix": "node scripts/live-matrix.mjs",
    "live:audit": "node scripts/live-matrix.mjs --configured-only --audit",
    "live:target": "node scripts/live-target.mjs",
    "live:configured": "node scripts/live-matrix.mjs --configured-only",
    "release:check": "pnpm run lint && pnpm run build && pnpm test && pnpm run smoke:productize && pnpm run smoke:hermes-e2e && pnpm run smoke:setup-chat && pnpm run smoke:provider-onboarding && pnpm run smoke:provider-interactive-onboarding && pnpm run smoke:mcp-runtime && pnpm run smoke:mutable-mcp-sidecar && pnpm run smoke:notion-readback && pnpm run smoke:github-readback && pnpm run smoke:mutable-action && pnpm run smoke:handoff-worker-race && pnpm run smoke:top-level-golden-path && pnpm run smoke:github-onboarding && pnpm run check:install && pnpm run smoke:install-e2e",
    "release:gate": "pnpm run release:check && pnpm run live:configured",
    "release:live": "pnpm run build && pnpm run live:matrix",
    "test": "vitest run tests",
    "start": "node dist/apps/cli/src/index.js"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.18.3",
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
